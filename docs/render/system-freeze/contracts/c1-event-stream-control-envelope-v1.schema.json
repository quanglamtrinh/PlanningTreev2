{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://planningtree.local/contracts/c1-event-stream-control-envelope-v1.schema.json",
  "title": "C1 Event Stream Control Envelope v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "event_type",
    "thread_id",
    "turn_id",
    "snapshot_version",
    "occurred_at_ms",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "stream_open",
        "replay_miss"
      ]
    },
    "thread_id": {
      "type": "string",
      "minLength": 1
    },
    "turn_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "snapshot_version": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "occurred_at_ms": {
      "type": "integer",
      "minimum": 0
    },
    "payload": {
      "type": "object"
    }
  }
}
