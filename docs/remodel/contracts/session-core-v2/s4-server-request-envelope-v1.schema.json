{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://planningtree.local/contracts/session-core-v2/s4-server-request-envelope-v1.schema.json",
  "title": "S4 Server Request Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "method",
    "threadId",
    "turnId",
    "itemId",
    "status",
    "occurredAtMs",
    "params"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "method": {
      "type": "string",
      "enum": [
        "item/tool/requestUserInput",
        "item/commandExecution/requestApproval",
        "item/fileChange/requestApproval",
        "item/permissions/requestApproval",
        "mcpServer/elicitation/request"
      ]
    },
    "threadId": {
      "type": "string",
      "minLength": 1
    },
    "turnId": {
      "type": [
        "string",
        "null"
      ]
    },
    "itemId": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "submitted",
        "resolved",
        "rejected",
        "expired"
      ]
    },
    "occurredAtMs": {
      "type": "integer",
      "minimum": 0
    },
    "params": {
      "type": "object"
    }
  }
}
