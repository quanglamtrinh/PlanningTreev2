# Required for AI split operations
OPENAI_API_KEY=sk-...

# Optional overrides
# PLANNINGTREE_DATA_ROOT=       Override app data directory (default: platform AppData)
# PLANNINGTREE_PORT=8000        Backend port
# PLANNINGTREE_SPLIT_MODEL=gpt-4o  OpenAI model for split generation
# PLANNINGTREE_SPLIT_TIMEOUT_SEC=120
# PLANNINGTREE_CODEX_CMD=       Path to Codex binary (default: auto-discover)
